# PantryOps Edge — environment template. Copy to .env and fill in real values; never commit .env.

# PostgreSQL connection string (psycopg 3 driver)
PANTRYOPS_DATABASE_URL=postgresql+psycopg://pantryops:pantryops@localhost:5432/pantryops

# Redis connection for Celery broker and result backend
PANTRYOPS_REDIS_URL=redis://localhost:6379/0

# Image storage backend: local | minio | s3
PANTRYOPS_STORAGE_BACKEND=minio

# S3-compatible storage (used when backend is minio or s3)
PANTRYOPS_S3_ENDPOINT_URL=http://localhost:9000
PANTRYOPS_S3_BUCKET=pantryops-images
PANTRYOPS_S3_ACCESS_KEY=changeme
PANTRYOPS_S3_SECRET_KEY=changeme
PANTRYOPS_S3_REGION=us-east-1

# OpenRouter API key for the planning/explanation agents (ADR 003)
PANTRYOPS_LLM_API_KEY=sk-or-changeme

# OpenRouter model id used by all agents
PANTRYOPS_LLM_MODEL=deepseek/deepseek-v4-flash

# OpenRouter API base URL
PANTRYOPS_LLM_BASE_URL=https://openrouter.ai/api/v1

# LangSmith tracing for LangGraph agent runs (leave tracing false to disable)
LANGSMITH_API_KEY=lsv2-changeme
LANGSMITH_TRACING=false

# Open Food Facts base URL (product enrichment; no key required)
PANTRYOPS_OFF_BASE_URL=https://world.openfoodfacts.org

# USDA FoodData Central API key (nutrition enrichment)
PANTRYOPS_USDA_API_KEY=changeme
